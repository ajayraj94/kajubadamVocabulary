# =============================================================================
# Kajubadam Vocabulary — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# 🔐 SECURITY NOTES:
#   - Never commit .env.local or any .env file to git
#   - All secrets MUST be set in Vercel dashboard for production
#   - Use strong, unique passwords/keys for each environment
# =============================================================================

# ── Site Configuration ───────────────────────────────────────────────────────
SITE_URL=https://kajubadamvocabulary.in

# ── Supabase (Authentication + Database) ────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
# NOTE: NEXT_PUBLIC_ prefixed vars are exposed to the browser!
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ⚠️ SUPER IMPORTANT: Service role key bypasses Row Level Security (RLS).
#    Used ONLY in server-side admin API routes. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Admin Panel ──────────────────────────────────────────────────────────────
# ⚠️ MUST be set! No fallback password exists in code.
#    Admin panel is accessible at: https://your-site.com/iswebkaram
ADMIN_PASSWORD=your-strong-admin-password-here

# Optional: Custom salt for admin token derivation (defaults to timestamp)
# ADMIN_TOKEN_SALT=your-custom-salt-here

# ── Razorpay (Payment Processing) ───────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com/app/keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here

# ⚠️ Webhook secret for verifying Razorpay payment callbacks.
#    Set this in Razorpay Dashboard → Settings → Webhooks
#    Webhook URL: https://your-site.com/api/payment/webhook
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret-here

# ── Product Prices (optional — uses defaults if not set) ─────────────────────
# Prices are in INR. Override defaults from lib/products.ts
# NEXT_PUBLIC_PART1_PRICE=299
# NEXT_PUBLIC_PART2_PRICE=399
# NEXT_PUBLIC_ERRORDETECTION_PRICE=110
# NEXT_PUBLIC_BUNDLE_PRICE=549

# ── Google Tag Manager (optional) ───────────────────────────────────────────
# Already hardcoded as GTM-KFLQ24ZX in layout.tsx
# NEXT_PUBLIC_GTM_ID=GTM-KFLQ24ZX
